{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "./frontend/dist",
    "strict": true,
    "lib": ["DOM", "ES2020"],
    "skipLibCheck": true,
    "noEmitOnError": true
  },
  "include": ["frontend/src/**/*.ts", "shared/**/*.ts"]
}